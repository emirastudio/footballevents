# ─────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://fe_user:fe_pass@localhost:5432/footballevents?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:6969"

# Auth.js v5 — generate via: openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:6969"

# Optional: Google OAuth (Auth.js auto-detects when both are set)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────────────────
# Email (Resend)
# Without RESEND_API_KEY — emails log to console (dev no-op).
# ─────────────────────────────────────────────────────
EMAIL_FROM="FootballEvents.eu <noreply@footballevents.eu>"
RESEND_API_KEY=""

# Local SMTP (Mailpit) — only used by docker-compose
SMTP_HOST="localhost"
SMTP_PORT="1025"

# ─────────────────────────────────────────────────────
# Storage (S3 / MinIO / Cloudflare R2)
# Local dev → MinIO. Prod → Cloudflare R2 (recommended) or S3.
# ─────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minio_admin"
S3_SECRET_KEY="minio_admin_pass"
S3_BUCKET="footballevents"
S3_PUBLIC_URL="http://localhost:9000/footballevents"

# ─────────────────────────────────────────────────────
# Stripe
# Required for subscriptions and boosts. Without these,
# /pricing CTAs redirect to ?stripe=not-configured.
# ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Recurring price IDs (from Stripe dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_ANNUAL=""

# ─────────────────────────────────────────────────────
# Supabase Realtime (optional — used later for chat)
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─────────────────────────────────────────────────────
# Observability — Sentry (optional)
# ─────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─────────────────────────────────────────────────────
# Rate limiting — Upstash Redis (optional, free tier)
# Without these — limiter is a no-op (dev only).
# ─────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────
# Set to "1" on prod to hide seed/demo events from the catalog.
HIDE_DEMO=""

# ─────────────────────────────────────────────────────
# SEO — search-engine site verification
# Paste the value (just the content="..." part) from each console
# ─────────────────────────────────────────────────────
# Google Search Console → Settings → Ownership verification → HTML tag
GOOGLE_SITE_VERIFICATION=""
# Bing Webmaster Tools → Settings → Verify ownership → Meta tag
BING_SITE_VERIFICATION=""

# ─────────────────────────────────────────────────────
# Analytics — privacy-friendly, cookie-less. Pick ONE provider.
# ─────────────────────────────────────────────────────
# Plausible (https://plausible.io — €9/mo hosted, or self-host free)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Override only for self-hosted: e.g. "https://plausible.mydomain.eu/js/script.js"
NEXT_PUBLIC_PLAUSIBLE_SCRIPT=""

# Umami (https://umami.is — free cloud tier, or self-host)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_SCRIPT=""

# Google Analytics 4 — loaded with Consent Mode v2.
# Default consent state = denied; granted only after the user clicks "Accept"
# in the cookie banner. No GA cookies are written until then.
NEXT_PUBLIC_GA_ID=""
